{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Deployable",
  "description": "A deployable is a runnable process. It declares runtime role, statefulness, identity, storage, resources, and failure domain.",
  "type": "object",
  "required": ["name", "type", "version"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Deployable identifier (kebab-case)"
    },
    "type": {
      "type": "string",
      "enum": ["server", "worker", "bff", "gateway", "projector", "relay", "reconciler", "runner"],
      "description": "Deployable process type"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version"
    },
    "description": {
      "type": "string"
    },
    "services": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Services included in this deployable"
    },
    "runtime_profile": {
      "type": "string"
    },
    "statefulness": {
      "type": "string",
      "enum": ["stateless", "checkpointed", "stateful"]
    },
    "required_identity": {
      "type": "string",
      "enum": ["ephemeral", "stable"]
    },
    "required_storage": {
      "type": "string",
      "enum": ["none", "ephemeral", "persistent"]
    },
    "scaling_axis": {
      "type": "array",
      "items": { "type": "string" }
    },
    "failure_domain": {
      "type": "string"
    },
    "resources": {
      "type": "array",
      "items": { "type": "string" },
      "description": "External resources required by this deployable"
    },
    "entry_point": {
      "type": "string",
      "description": "Path to main entry file"
    },
    "package": {
      "type": "string",
      "description": "Cargo package name (for Rust) or npm package name (for TS)"
    },
    "health_check": {
      "type": "object",
      "properties": {
        "path": { "type": "string" },
        "port": { "type": "integer" },
        "interval_seconds": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "environment_variables": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "sensitive": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "observability": {
      "type": "object",
      "properties": {
        "health_check": {
          "type": "object",
          "properties": {
            "endpoint": { "type": "string" },
            "interval": { "type": "string" },
            "timeout": { "type": "string" }
          },
          "additionalProperties": false
        },
        "readiness_check": {
          "type": "object",
          "properties": {
            "endpoint": { "type": "string" },
            "interval": { "type": "string" },
            "timeout": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "ports": {
      "type": "array",
      "items": { "type": "integer" },
      "description": "Network ports exposed by this deployable"
    },
    "independent_deploy": {
      "type": "boolean",
      "description": "Whether this deployable can be deployed independently from its parent"
    },
    "embedded_in": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Parent deployables this deployable can be embedded in"
    }
  },
  "additionalProperties": false
}
