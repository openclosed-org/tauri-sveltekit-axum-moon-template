{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Workflow",
  "description": "A multi-step business process that orchestrates services and events",
  "type": "object",
  "required": ["name", "version", "steps"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "description": {
      "type": "string"
    },
    "trigger": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["http_request", "event", "schedule", "manual"]
        },
        "source": { "type": "string" }
      }
    },
    "steps": {
      "type": "array",
      "items": { "$ref": "#/definitions/step" }
    },
    "timeout": {
      "type": "string",
      "description": "ISO 8601 duration (e.g., PT30S)"
    },
    "retry_policy": {
      "type": "string",
      "description": "Reference to retry policy in policies/"
    }
  },
  "definitions": {
    "step": {
      "type": "object",
      "required": ["name", "action"],
      "properties": {
        "name": { "type": "string" },
        "action": {
          "type": "string",
          "description": "Service method or event to invoke"
        },
        "next": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Next step names on success"
        },
        "on_failure": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Next step names on failure"
        }
      }
    }
  }
}
