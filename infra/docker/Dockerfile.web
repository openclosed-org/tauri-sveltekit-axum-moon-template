# Multi-stage Dockerfile for the SvelteKit Web frontend
# Compatible with Dockerfile syntax used by Podman.
#
# The app uses @sveltejs/adapter-static, which produces static files.
# We serve them with static-web-server (Rust, distroless) for production.
#
# Build:
#   podman build -f infra/docker/Dockerfile.web -t web-app .
#
# Run:
#   podman run -p 3000:3000 web-app

# ── Stage 1: Builder ─────────────────────────────────────────
FROM oven/bun:1-alpine AS builder

RUN apk add --no-cache git

WORKDIR /app

# Install dependencies first for layer caching
COPY package.json bun-workspace.yaml bun.lockb* ./
COPY apps/web/package.json ./apps/web/
COPY packages/ui/package.json ./packages/ui/ 2>/dev/null || true

RUN bun install --frozen-lockfile 2>/dev/null || bun install

# Copy all source code
COPY apps/web/ ./apps/web/
COPY packages/ ./packages/

# Build the web app
WORKDIR /app/apps/web
RUN bun run build

# ── Stage 2: Serve with static-web-server (distroless) ──────
FROM ghcr.io/static-web-server/static-web-server:2 AS runtime

# Copy built static files
COPY --from=builder /app/apps/web/build /app/web-build

WORKDIR /app/web-build

EXPOSE 3000

# static-web-server CLI flags
CMD [
    "--host", "0.0.0.0",
    "--port", "3000",
    "--root", "/app/web-build",
    "--page-fallback", "/app/web-build/index.html",
    "--compression",
    "--security-headers",
    "--log-level", "info"
]
