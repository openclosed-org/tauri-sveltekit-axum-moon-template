# ── Google OAuth ────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Backend API ─────────────────────────────────────────────
API_URL=http://localhost:3001

# ── Logging ─────────────────────────────────────────────────
RUST_LOG=info

# ── Build Cache (sccache) ──────────────────────────────────
# Install: cargo install sccache --locked
# # SCCACHE_DIR=~/.cache/sccache
# RUSTC_WRAPPER=sccache

# ── Axum Server (figment, APP_ prefix) ─────────────────────
# Read by servers/bff/web-bff via figment Env::prefixed("APP_")
# See config struct: servers/bff/web-bff/src/config.rs
# In production secrets come from SOPS/Kustomize/Flux, not .env files.

APP_SERVER_HOST=0.0.0.0
APP_SERVER_PORT=3001
APP_SERVER_REQUEST_TIMEOUT_SECS=30

# Database (default: memory)
APP_DATABASE_URL=memory
APP_DATABASE_NS=app
APP_DATABASE_DB=main

# Cache (default: 10000 entries, 300s TTL)
APP_CACHE_MAX_CAPACITY=10000
APP_CACHE_TTL_SECS=300

# JWT (default: dev-secret-change-in-production — MUST change for production)
APP_AUTH_JWT_SECRET=dev-secret-change-in-production
APP_AUTH_JWT_EXPIRATION_SECS=86400
