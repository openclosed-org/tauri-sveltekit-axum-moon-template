# Local environment template for `web-bff`.
# Runtime config is loaded from `APP_` variables in `servers/bff/web-bff/src/config.rs`.
# Production / cluster secrets still belong to SOPS, not `.env`.

# ── Host Process / Logging ──────────────────────────────────
RUST_LOG=info,web_bff=debug

# ── Web BFF HTTP ────────────────────────────────────────────
APP_SERVER_HOST=0.0.0.0
APP_SERVER_PORT=3010

# Protected API auth mode:
# - jwt: default, require Authorization Bearer token
# - dev_headers: local backend-only mode, accepts x-dev-user-sub headers
APP_AUTH_MODE=jwt

# ── Storage ─────────────────────────────────────────────────
# Local host-process default: embedded libSQL/SQLite file.
APP_DATABASE_URL=file:./.data/web-bff.db
# Remote libSQL/Turso example:
# APP_TURSO_URL=libsql://your-db.turso.io
# APP_TURSO_AUTH_TOKEN=

# ── Auth: fallback local dev JWT ────────────────────────────
# Used when no Zitadel issuer is configured.
APP_JWT_SECRET=dev-secret-change-in-production

# ── Auth: Zitadel resource-server validation ────────────────
# Local Podman example values are produced by:
#   bash infra/local/scripts/bootstrap-auth.sh bootstrap
# and written into `infra/local/generated/auth.env`.
APP_ZITADEL_ISSUER=
APP_ZITADEL_AUDIENCE=

# Optional: use Zitadel introspection for opaque tokens or revocation-aware validation.
APP_ZITADEL_INTROSPECTION_CLIENT_ID=
APP_ZITADEL_INTROSPECTION_CLIENT_SECRET=

# ── AuthZ: OpenFGA ──────────────────────────────────────────
APP_OPENFGA_ENDPOINT=
APP_OPENFGA_STORE_ID=
APP_OPENFGA_AUTHORIZATION_MODEL_ID=
